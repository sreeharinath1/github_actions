# ═══════════════════════════════════════════════════════
# ProjectA Production Environment Variables
# Copy to .env and fill in real values — NEVER commit .env
# ═══════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# ── Keycloak ──────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_admin
KEYCLOAK_BACKEND_SECRET=change_me_backend_secret

# ── RabbitMQ ──────────────────────────────────────────
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change_me_rabbitmq_password

# ── Redis ─────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── Email / SMTP ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@projecta.com

# ── Twilio SMS ────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ── Grafana ───────────────────────────────────────────
GRAFANA_PASSWORD=change_me_grafana_password

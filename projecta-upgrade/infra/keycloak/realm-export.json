{
  "realm": "projecta",
  "displayName": "ProjectA",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "USER",  "description": "Standard application user" },
      { "name": "ADMIN", "description": "Full administrative access" },
      { "name": "SUPPORT", "description": "Customer support agent" }
    ]
  },
  "clients": [
    {
      "clientId": "projecta-frontend",
      "name": "ProjectA Frontend",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "https://app.projecta.com/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "https://app.projecta.com"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "projecta-backend",
      "name": "ProjectA Backend Services",
      "enabled": true,
      "publicClient": false,
      "secret": "${KEYCLOAK_BACKEND_SECRET}",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect"
    }
  ],
  "smtpServer": {
    "host": "${SMTP_HOST}",
    "port": "${SMTP_PORT}",
    "from": "${SMTP_FROM}",
    "auth": "true",
    "starttls": "true",
    "user": "${SMTP_USERNAME}",
    "password": "${SMTP_PASSWORD}"
  }
}
